# ============================================
# Solana Sniper Bot - Konfiguratsiya
# ============================================

# === RPC Endpoints ===
RPC_HTTPS=https://api.mainnet-beta.solana.com
RPC_WSS=wss://api.mainnet-beta.solana.com

# Shaxsiy yoki to'langan RPC (tavsiya etiladi - tezroq)
# RPC_HTTPS=https://your-private-rpc.com
# RPC_WSS=wss://your-private-rpc.com

# === Wallet ===
# Base58 formatida private key
PRIVATE_KEY=your_base58_private_key_here

# === Trading Sozlamalari ===
# Slippage foizi (masalan: 15 = 15%)
SLIPPAGE=15

# Maksimal pozitsiya hajmi (SOL da)
MAX_POSITION_SIZE=0.1

# Minimal likvidlik (SOL da)
MIN_LIQUIDITY=1.0

# === Exit Strategiya ===
# Take Profit foizi (masalan: 50 = 50%)
TAKE_PROFIT=50

# Stop Loss foizi (masalan: 30 = 30%)
STOP_LOSS=30

# Maksimal ushlab turish vaqti (soniyalarda)
MAX_HOLD_TIME=120

# === Priority Fee ===
# Priority fee (microlamports da, 0 = avtomatik)
PRIORITY_FEE=100000

# === Jito (MEV) ===
# Jito tip miqdori (lamports da, 0 = o'chiq)
JITO_TIP=0
JITO_ENDPOINT=https://mainnet.block-engine.jito.wtf

# === Monitoring ===
# Pump.fun program ID
PUMP_FUN_PROGRAM=6EF8rrecthR5Dkzon8Nwu78hRvfCKubJ14M5uBEwF6P

# Raydium AMM program ID
RAYDIUM_AMM_PROGRAM=675kPX9MHTjS2zt1qfr1NYHuzeLXfQM9H24wFSUt1Mp8

# === Logging ===
# Log darajasi: trace, debug, info, warn, error
LOG_LEVEL=info

# === Xavfsizlik ===
# Maksimal bir vaqtdagi pozitsiyalar soni
MAX_CONCURRENT_POSITIONS=3

# Token tekshirish vaqt chegarasi (ms)
ANALYSIS_TIMEOUT_MS=500
