# WHALE TRACKER PRO - Environment Configuration Example
# Copy this file to .env and fill in your actual credentials.

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram User ID (to authorize commands)
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Moralis API Key (from moralis.io)
MORALIS_API_KEY=your_moralis_api_key_here

# Gemini AI API Key (from aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Helius RPC API Key (from helius.dev)
HELIUS_API_KEY=your_helius_api_key_here
